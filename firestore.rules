rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // =========================================================================
    // HELPER FUNCTIONS
    // =========================================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isChatParticipant(chatData) {
      return request.auth.uid in chatData.participants;
    }

    function isChatAdmin(chatData) {
      return request.auth.uid in chatData.admins;
    }

    function isHQAdmin() {
      return request.auth.token.email in [
        'ihenacho23@gmail.com', 
        'ephraimloveworld1@gmail.com', 
        'takeshopstores@gmail.com', 
        'nnennawealth@gmail.com',
        'joykures@gmail.com',
        'styleirech@gmail.com'
      ];
    }

    // =========================================================================
    // USERS, PROFILES & PRESENCE
    // =========================================================================
    match /profiles/{userId} {
      allow read: if true;
      allow write: if isAuthenticated() && (isOwner(userId) || isHQAdmin());
    }

    match /user_sessions/{uid} {
      allow read, write: if isAuthenticated() && isOwner(uid);
    }

    match /kingschat_auth_sessions/{sessionId} {
      allow read, write: if true;
    }

    match /user_preferences/{userId} {
      allow read, write: if isAuthenticated() && isOwner(userId);
    }

    match /user_connections/{connectionId} {
      allow read, write: if isAuthenticated();
    }

    match /user_activity/{activityId} {
      allow read, write: if isAuthenticated();
    }

    match /friend_requests/{requestId} {
      allow read, write: if isAuthenticated();
    }

    match /presence/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && isOwner(userId);
    }

    match /admin_users/{adminId} {
      allow read, write: if true;
    }

    match /hq_members/{memberId} {
      allow read: if isAuthenticated();
      allow write: if true;
    }

    // =========================================================================
    // UNIFIED NOTIFICATIONS
    // =========================================================================
    match /notifications/{notificationId} {
      // NOTE: The React Native app downloads the stream and filters in-memory.
      // Therefore, this rule must remain open for all authenticated users.
      // To strictly secure this in the future, the mobile app must split its queries
      // by target_audience instead of doing a global orderBy query.
      allow read: if isAuthenticated();
      allow create, update, delete: if isAuthenticated();
    }

    match /user_notifications/{readStateId} {
      allow read, write: if isAuthenticated();
    }

    match /user_groups/{groupId} {
      allow read, write: if isAuthenticated();
    }

    match /push_notifications/{notificationId} {
      allow read, write: if true;
    }

    match /fcm_tokens/{tokenId} {
      allow read: if isAuthenticated();
      allow write: if true;
    }

    // =========================================================================
    // CHAT V2, CALLS & WEBRTC
    // =========================================================================
    match /chats_v2/{chatId} {
      allow read, write: if isAuthenticated();
    }

    match /messages_v2/{messageId} {
      allow read, write: if isAuthenticated();
    }

    match /typing_v2/{documentId} {
      allow read, write: if isAuthenticated();
    }

    match /calls_v2/{callId} {
      allow read, write: if isAuthenticated();
      match /{document=**} {
        allow read, write: if isAuthenticated();
      }
    }

    match /statuses_v2/{statusId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['viewers', 'likes']);
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    match /media_doodles/{document=**} {
      allow read, write: if isAuthenticated();
    }

    match /support_messages/{messageId} {
      allow read, create: if isAuthenticated() && (request.resource.data.chatId == request.auth.uid || resource.data.chatId == request.auth.uid || isHQAdmin());
      allow update, delete: if isAuthenticated() && isHQAdmin();
    }

    // =========================================================================
    // MEDIA, VIDEO & NETFLIX-STYLE FEATURES
    // =========================================================================
    match /media/{mediaId} {
      allow read: if true;
      allow create, update, delete: if isAuthenticated() && isHQAdmin();
    }

    match /media_videos/{videoId} {
      allow read, create, update, delete: if isAuthenticated();
    }

    match /video-upload/{docId} {
      allow read, create, update, delete: if isAuthenticated();
    }

    match /cloudinary_media/{mediaId} {
      allow read, write: if isAuthenticated() || true;
    }

    match /media_genres/{genreId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    match /media_categories/{categoryId} {
      allow read, write: if true;
    }

    match /media_analytics/{analyticsId} {
      allow read, write: if isAuthenticated();
    }

    match /media_comments/{commentId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.userId;
      allow update, delete: if isAuthenticated() && (request.auth.uid == resource.data.userId || isHQAdmin());
    }

    match /watch_history/{historyId} {
      allow read, write: if isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid);
    }

    match /user_watch_history/{userId} {
      allow read, write: if isAuthenticated() && isOwner(userId);
    }

    match /favorites/{favoriteId} {
      allow read, write: if isAuthenticated();
    }

    match /user_favorites/{userId} {
      allow read, write: if isAuthenticated() && isOwner(userId);
    }

    match /user_song_notes/{noteId} {
      allow read, write: if isAuthenticated() && noteId.matches(request.auth.uid + '_.*');
    }

    match /user_playlists/{playlistId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    match /media_playlists/{playlistId} {
      allow read, create, update, delete: if isAuthenticated();
    }

    match /admin_playlists/{playlistId} {
      allow read, write: if true;
    }

    match /media_channels/{channelId} {
      allow read: if isAuthenticated();
      allow create, delete: if isAuthenticated() && isHQAdmin();
      allow update: if isAuthenticated() && (
        isHQAdmin() || 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['subscriberCount', 'videoCount', 'updatedAt'])
      );
    }

    match /channel_subscriptions/{subId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // =========================================================================
    // MUSIC & AUDIOLAB
    // =========================================================================
    match /master_library/{songId} {
      allow read: if isAuthenticated();
      allow write: if true;
    }

    match /master_programs/{programId} {
      allow read: if isAuthenticated();
      allow write: if true;
    }

    match /master_songs/{songId} {
      allow read: if isAuthenticated();
      allow write: if true;
    }

    match /submitted_songs/{submissionId} {
      allow read: if isAuthenticated() && (resource.data.submittedBy.userId == request.auth.uid || true);
      allow create: if isAuthenticated() && request.resource.data.submittedBy.userId == request.auth.uid;
      allow update, delete: if isAuthenticated();
    }

    match /song_history/{historyId} {
      allow read, write: if true;
    }

    match /song_ministries/{ministryId} {
      allow read: if isAuthenticated();
      allow write: if true;
    }

    match /song_ministry_history/{historyId} {
      allow read: if isAuthenticated();
      allow write: if true;
    }

    match /song_ministry_summaries/{summaryId} {
      allow read: if isAuthenticated();
      allow write: if true;
    }

    match /ministered_songs/{ministeredId} {
      allow read: if isAuthenticated();
      allow write: if true;
    }

    match /audiolab_playlists/{playlistId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isHQAdmin());
    }

    match /audiolab_songs/{songId} {
      allow read: if isAuthenticated();
      allow write: if true;
    }

    match /audiolab_projects/{projectId} {
      allow read, write: if isAuthenticated();
    }

    match /audiolab_progress/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && isOwner(userId);
    }

    match /audiolab_sessions/{sessionId} {
      allow read, write: if isAuthenticated();
    }

    // =========================================================================
    // ZONES, SUBGROUPS & EVENTS
    // =========================================================================
    match /zones/{zoneId} {
      allow read: if isAuthenticated();
      allow write: if true;
    }

    match /zone_members/{memberId} {
      allow read: if isAuthenticated();
      allow write: if true;
    }

    match /zone_user_groups/{groupId} {
      allow read: if isAuthenticated();
      allow write: if true;
    }

    match /subgroups/{subgroupId} {
      allow read: if isAuthenticated();
      allow write: if true;
    }

    match /subgroup_members/{memberId} {
      allow read: if isAuthenticated();
      allow write: if true;
    }

    match /subgroup_songs/{songId} {
      allow read: if isAuthenticated();
      allow write: if true;
    }

    match /subgroup_praise_nights/{rehearsalId} {
      allow read: if isAuthenticated();
      allow write: if true;
    }

    match /groups/{groupId} {
      allow read, write: if isAuthenticated();
    }

    match /group_posts/{postId} {
      allow read, write: if isAuthenticated();
    }

    match /praise_nights/{praiseNightId} {
      allow read, write: if true;
    }

    match /praise_night_songs/{songId} {
      allow read, write: if true;
    }

    match /calendar_events/{eventId} {
      allow read: if isAuthenticated();
      allow write: if true;
    }

    match /event_attendees/{attendeeId} {
      allow read: if isAuthenticated();
      allow write: if true;
    }

    match /birthdays/{birthdayId} {
      allow read: if isAuthenticated();
      allow write: if true;
    }

    match /upcoming_events/{eventId} {
      allow read, write: if true;
    }

    match /attendance/{attendanceId} {
      allow read: if isAuthenticated();
      allow write: if true;
    }

    match /achievements/{achievementId} {
      allow read: if isAuthenticated();
      allow write: if true;
    }

    match /schedule_categories/{categoryId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    match /schedule_songs/{songId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    match /schedule_programs/{programId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // Zone specific modules
    match /zone_songs/{songId} { allow read: if isAuthenticated(); allow write: if true; }
    match /zone_praise_nights/{praiseNightId} { allow read: if isAuthenticated(); allow write: if true; }
    match /zone_categories/{categoryId} { allow read: if isAuthenticated(); allow write: if true; }
    match /zone_page_categories/{pageCategoryId} { allow read: if isAuthenticated(); allow write: if true; }
    match /zone_song_history/{historyId} { allow read: if isAuthenticated(); allow write: if true; }
    match /zone_cloudinary_media/{mediaId} { allow read: if isAuthenticated(); allow write: if true; }
    match /zone_notifications/{notificationId} { allow read: if isAuthenticated(); allow write: if true; }
    match /zone_analytics/{analyticsId} { allow read: if isAuthenticated(); allow write: if true; }
    match /zone_comments/{commentId} { allow read: if isAuthenticated(); allow write: if true; }
    match /zone_admin_messages/{messageId} { allow read: if isAuthenticated(); allow write: if true; }
    match /zone_attendance/{attendanceId} { allow read: if isAuthenticated(); allow write: if true; }
    match /zone_achievements/{achievementId} { allow read: if isAuthenticated(); allow write: if true; }

    // =========================================================================
    // PAYMENTS & SUBSCRIPTIONS
    // =========================================================================
    match /payment_records/{paymentId} {
      allow read, create: if true;
      allow update, delete: if isAuthenticated();
    }

    match /subscription_audit_logs/{logId} {
      allow read, create: if true;
      allow update: if false;
      allow delete: if isAuthenticated();
    }

    match /zone_subscriptions/{zoneId} {
      allow read: if isAuthenticated();
      allow write: if true;
    }

    match /payments/{paymentId} {
      allow read, update, delete: if isAuthenticated() && isHQAdmin();
      allow create: if true;
    }

    match /individual_subscriptions/{subscriptionId} {
      allow read, write: if isAuthenticated() && (subscriptionId == request.auth.uid || resource.data.userId == request.auth.uid || request.resource.data.userId == request.auth.uid);
    }

    // =========================================================================
    // LEGACY & MIGRATION CHAT (WHATSAPP)
    // =========================================================================
    match /chats/{chatId} {
      allow read, create, update, delete: if isAuthenticated();
    }

    match /messages/{messageId} {
      allow read, write: if isAuthenticated();
    }

    match /chat_users/{userId} {
      allow read, write: if isAuthenticated();
    }

    match /whatsapp_users/{userId} { allow read, write: if isAuthenticated(); }
    match /whatsapp_chats/{chatId} { allow read, write: if isAuthenticated(); }
    match /whatsapp_messages/{messageId} { allow read, write: if isAuthenticated(); }
    match /whatsapp_contacts/{contactId} { allow read, write: if isAuthenticated() && resource.data.userId == request.auth.uid; }
    match /whatsapp_starred_messages/{starId} { allow read, write: if isAuthenticated() && resource.data.userId == request.auth.uid; }
    match /whatsapp_broadcasts/{broadcastId} { 
      allow read: if isAuthenticated() && (resource.data.createdBy == request.auth.uid || request.auth.uid in resource.data.recipients);
      allow write: if isAuthenticated() && resource.data.createdBy == request.auth.uid;
    }
    match /whatsapp_media_uploads/{uploadId} { allow read, write: if isAuthenticated() && resource.data.uploadedBy == request.auth.uid; }

    // =========================================================================
    // OTHER / SYSTEM / DEPRECATED
    // =========================================================================
    match /sys_metadata/{zoneId} {
      allow read, write: if isAuthenticated();
      match /{metadataType}/{docId} {
        allow read, write: if isAuthenticated();
      }
    }

    match /activity_logs/{logId} {
      allow read, create: if isAuthenticated();
      allow update, delete: if false;
    }

    match /simplified_analytics/{analyticsId} {
      allow read: if isAuthenticated();
      allow write: if true;
    }

    match /songs/{songId} { allow read, write: if true; }
    match /admin_messages/{messageId} { allow read: if isAuthenticated(); allow create, delete: if true; allow update: if false; }
    match /song_notifications/{notificationId} { allow read, create, update, delete: if isAuthenticated(); }
    match /comments/{commentId} { allow read, write: if isAuthenticated(); }
    match /categories/{categoryId} { allow read, write: if true; }
    match /page_categories/{pageCategoryId} { allow read, write: if true; }
    match /voice_messages/{voiceId} { allow read, write: if isAuthenticated(); }
    match /webrtc_sessions/{sessionId} { allow read, write: if isAuthenticated(); }
    match /conversations/{conversationId} { allow read, write: if isAuthenticated(); }

    // =========================================================================
    // DEFAULT DENY ALL
    // =========================================================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
